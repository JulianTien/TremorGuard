SECRET_KEY=replace-with-a-random-32-byte-secret
CLINICAL_DATABASE_URL=sqlite:///./clinical.db
IDENTITY_DATABASE_URL=sqlite:///./identity.db

# DashScope / Qwen OpenAI-compatible Chat API
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_MEDICAL_EXTRACTION_MODEL=qwen-vl-plus
DASHSCOPE_MEDICAL_REPORT_MODEL=qwen-plus
DASHSCOPE_MEDICAL_PROMPT_VERSION=medical-records-v1
DASHSCOPE_TIMEOUT_SECONDS=60
DASHSCOPE_ENABLE_SEARCH=false
MEDICAL_RECORDS_STORAGE_DIR=./storage/medical_records
MEDICAL_RECORDS_MAX_UPLOAD_BYTES=5000000
